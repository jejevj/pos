VITE_API_URL=http://localhost:8000/api

# WhatsApp / WAHA is OPT-IN. Leave VITE_WAHA_ENABLED=false (the default) and the
# frontend will not open the WAHA WebSocket or call the WAHA REST API at all.
# To turn WhatsApp on:
#   1. set VITE_WAHA_ENABLED=true
#   2. set VITE_WAHA_API_KEY to a real, non-placeholder key (NOT `change-me`)
#   3. rebuild the frontend (Vite envs are baked at build time)
VITE_WAHA_ENABLED=false
VITE_WAHA_URL=http://localhost:3000
VITE_WAHA_API_KEY=
