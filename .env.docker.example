# =====================================================================
# Docker Compose environment for the full POS stack.
# Copy to .env.docker (loaded by the backend container via env_file) AND
# to .env at repo root (read by docker-compose itself for ${VAR} expansion).
#
#     cp .env.docker.example .env.docker
#     cp .env.docker.example .env
#
# Defaults below are wired for the user's existing setup: a Postgres
# container on the docker host exposing 5432, database `pos_sc`. You
# really only need to set APP_KEY and WAHA_API_KEY before `docker compose
# up -d --build`.
# =====================================================================

# ----- Timezone -----------------------------------------------------------
# Applied to every container (backend, proxy, frontend, redis, waha,
# optional postgres) via the TZ env var. Drives:
#   - nginx access-log $time_local on backend + proxy
#   - PHP date()/Carbon (also pinned via php.ini date.timezone and
#     Laravel's APP_TIMEZONE below)
#   - supervisor / php-fpm log lines
# Note: `docker logs` prefixes each line with the daemon's UTC clock
# when invoked with --timestamps. The application log content itself
# follows TZ; the docker daemon prefix does not.
TZ=Asia/Jakarta
APP_TIMEZONE=Asia/Jakarta

# ----- Public-facing ports ------------------------------------------------
# POS app (frontend + Laravel API) is fronted by the nginx proxy on APP_PORT.
# WAHA is a stand-alone service published on its own localhost-bound port and
# tunneled separately (Cloudflare Tunnel -> waha.ourtestcloud.my.id).
APP_PORT=9080
APP_URL=http://localhost:9080
FRONTEND_URL=http://localhost:9080
WAHA_PORT=9081

# ----- Laravel ------------------------------------------------------------
APP_NAME=POS
APP_ENV=production
APP_DEBUG=false
# Generate once with: docker compose run --rm backend php artisan key:generate --show
APP_KEY=
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

# Sanctum SPA auth — keep host:port pairs that match APP_URL
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:9080,127.0.0.1,127.0.0.1:9080
SESSION_DOMAIN=null

# Cache / queue / session backed by Redis inside the stack
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# Whether the backend container auto-runs migrations and a queue worker on boot
RUN_MIGRATIONS=true
RUN_QUEUE_WORKER=true

# ----- Database (external Postgres by default) ---------------------------
# The stack does NOT start its own Postgres by default. It connects to the
# Postgres container already running on this Docker host, exposing 5432.
# `host.docker.internal` (not 127.0.0.1) resolves to the host from inside
# the backend container, thanks to `extra_hosts` on that service.
DB_CONNECTION=pgsql
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=pos_sc
DB_USERNAME=postgres
DB_PASSWORD=qwert12345!

# ----- Bundled Postgres (optional, profile: internal-db) -----------------
# Only used when you start the stack with `--profile internal-db`. In that
# case set DB_HOST=postgres (the service name) and make sure DB_DATABASE /
# DB_USERNAME / DB_PASSWORD match the POSTGRES_* values below.
POSTGRES_DB=pos_sc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=qwert12345!

# ----- Redis --------------------------------------------------------------
# Optional. Leave empty to run Redis without auth (internal network only).
REDIS_PASSWORD=

# ----- WAHA (WhatsApp gateway) — OPTIONAL, STAND-ALONE -------------------
# WAHA is OFF by default. The POS app boots fine with these values blank.
# WAHA runs as its OWN service, published only on 127.0.0.1:${WAHA_PORT}
# (default 9081). Expose it to the internet via Cloudflare Tunnel, e.g.
#   waha.ourtestcloud.my.id -> http://localhost:9081
#
# To turn WhatsApp on inside POS:
#   1. fill in strong random values for WAHA_API_KEY + dashboard / swagger
#      credentials below
#   2. set WAHA_ENABLED=true
#   3. point WAHA_BASE_URL at the public tunnel hostname (default) OR at
#      the internal service name http://waha:3000 if POS and WAHA share the
#      same docker network
#   4. start WAHA on its own: `docker compose up -d waha`
#   5. restart the backend so it picks up the new env: `docker compose up -d backend`
WAHA_ENABLED=false
WAHA_BASE_URL=https://waha.ourtestcloud.my.id
WAHA_SESSION=default

# REQUIRED when WAHA_ENABLED=true. Generate a strong random string, e.g.:
#   openssl rand -hex 32
# Do NOT commit the real value. Leave blank in source control.
WAHA_API_KEY=

# Dashboard / Swagger basic-auth credentials baked into the WAHA container.
# Set to non-empty values before exposing WAHA publicly through the tunnel.
WAHA_DASHBOARD_USERNAME=
WAHA_DASHBOARD_PASSWORD=
WAHA_SWAGGER_USERNAME=
WAHA_SWAGGER_PASSWORD=

# What WAHA advertises for itself in webhook callbacks and Swagger. These
# should match the public Cloudflare Tunnel hostname.
WAHA_PUBLIC_HOSTNAME=waha.ourtestcloud.my.id
WAHA_PUBLIC_PORT=443
WAHA_PUBLIC_SCHEMA=https

# WEBJS (default), NOWEB, or GOWS — see WAHA docs
WAHA_ENGINE=WEBJS

# ----- Frontend build-time vars (baked into the Vue bundle) ---------------
# VITE_API_URL stays relative (`/api`) so Laravel + the SPA share an origin.
# WAHA lives on its own hostname now, so VITE_WAHA_URL is an absolute URL
# pointing at the Cloudflare Tunnel.
#
# IMPORTANT: Vite envs are baked at BUILD time. Changing these requires
# `docker compose build frontend` (and `up -d` to redeploy).
#
# VITE_WAHA_ENABLED must be `true` AND VITE_WAHA_API_KEY must be a real,
# non-placeholder key for the frontend to open the WAHA WebSocket / call the
# WAHA REST API. Otherwise the WhatsApp UI shows an "unconfigured" banner
# and the bundle does not generate any WAHA network traffic.
VITE_API_URL=/api
VITE_WAHA_ENABLED=false
VITE_WAHA_URL=https://waha.ourtestcloud.my.id
VITE_WAHA_API_KEY=

# ----- Mail (optional) ----------------------------------------------------
MAIL_MAILER=log
