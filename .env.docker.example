# =====================================================================
# Docker Compose environment for the full POS stack.
# Copy to .env.docker (loaded by the backend container via env_file) AND
# to .env at repo root (read by docker-compose itself for ${VAR} expansion).
#
#     cp .env.docker.example .env.docker
#     cp .env.docker.example .env
#
# Defaults below are wired for the user's existing setup: a Postgres
# container on the docker host exposing 5432, database `pos_sc`. You
# really only need to set APP_KEY and WAHA_API_KEY before `docker compose
# up -d --build`.
# =====================================================================

# ----- Public-facing port -------------------------------------------------
APP_PORT=9080
APP_URL=http://localhost:9080
FRONTEND_URL=http://localhost:9080

# ----- Laravel ------------------------------------------------------------
APP_NAME=POS
APP_ENV=production
APP_DEBUG=false
# Generate once with: docker compose run --rm backend php artisan key:generate --show
APP_KEY=
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

# Sanctum SPA auth — keep host:port pairs that match APP_URL
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:9080,127.0.0.1,127.0.0.1:9080
SESSION_DOMAIN=null

# Cache / queue / session backed by Redis inside the stack
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# Whether the backend container auto-runs migrations and a queue worker on boot
RUN_MIGRATIONS=true
RUN_QUEUE_WORKER=true

# ----- Database (external Postgres by default) ---------------------------
# The stack does NOT start its own Postgres by default. It connects to the
# Postgres container already running on this Docker host, exposing 5432.
# `host.docker.internal` (not 127.0.0.1) resolves to the host from inside
# the backend container, thanks to `extra_hosts` on that service.
DB_CONNECTION=pgsql
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=pos_sc
DB_USERNAME=postgres
DB_PASSWORD=qwert12345!

# ----- Bundled Postgres (optional, profile: internal-db) -----------------
# Only used when you start the stack with `--profile internal-db`. In that
# case set DB_HOST=postgres (the service name) and make sure DB_DATABASE /
# DB_USERNAME / DB_PASSWORD match the POSTGRES_* values below.
POSTGRES_DB=pos_sc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=qwert12345!

# ----- Redis --------------------------------------------------------------
# Optional. Leave empty to run Redis without auth (internal network only).
REDIS_PASSWORD=

# ----- WAHA (WhatsApp gateway) -------------------------------------------
WAHA_ENABLED=true
# CHANGE-ME — required, used both by WAHA itself and by Laravel/Vue
WAHA_API_KEY=
WAHA_SESSION=default
# WEBJS (default), NOWEB, or GOWS — see WAHA docs
WAHA_ENGINE=WEBJS

# ----- Frontend build-time vars (baked into the Vue bundle) ---------------
# Default values route through the proxy so only APP_PORT is exposed.
# Override only if you publish backend/waha on separate ports.
VITE_API_URL=/api
VITE_WAHA_URL=/waha
VITE_WAHA_API_KEY=${WAHA_API_KEY}

# ----- Mail (optional) ----------------------------------------------------
MAIL_MAILER=log
